{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZZZ stat tables",
  "definitions": {
    "stat": {
      "enum": ["Hp", "HpPct", "Atk", "AtkPct", "Def", "DefPct", "CritRate", "CritDmg", "Pen", "PenRatio", "AnomalyProficiency", "AnomalyMastery", "Impact", "EnergyRegen", "SheerForce", "PhysicalDmg", "FireDmg", "IceDmg", "ElectricDmg", "EtherDmg"]
    },
    "statNumberMap": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0 }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["slotMainStats", "mainStatMaxSRank", "substats", "substatRollMaxSRank"],
  "properties": {
    "slotMainStats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["1", "2", "3", "4", "5", "6"],
      "properties": {
        "1": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 },
        "2": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 },
        "3": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 },
        "4": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 },
        "5": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 },
        "6": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 }
      }
    },
    "mainStatMaxSRank": { "$ref": "#/definitions/statNumberMap" },
    "substats": { "type": "array", "items": { "$ref": "#/definitions/stat" }, "minItems": 1 },
    "substatRollMaxSRank": { "$ref": "#/definitions/statNumberMap" }
  }
}
