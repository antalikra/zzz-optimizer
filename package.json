{
  "name": "zzz-optimizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:wasm": "wasm-pack build packages/core-solver --target web --out-dir ../web/src/wasm --out-name core_solver",
    "dev": "pnpm --filter @zzz/web dev",
    "build": "pnpm --filter @zzz/web build",
    "validate:data": "node tools/validate-data.mjs",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "ajv": "^8.17.1"
  }
}
